{
  "name": "printly-agent",
  "version": "1.0.0",
  "description": "Printly print agent — system tray app for auto-printing Whatnot labels",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "me.printlyapp.agent",
    "productName": "Printly Agent",
    "copyright": "Copyright © 2026 Printly",
    "files": ["src/**/*", "build/icon.*"],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Printly Agent"
    }
  }
}
